{
  "manifest_version": 3,
  "name": "RoomList 空間採購清單",
  "short_name": "RoomList",
  "version": "0.3.0",
  "description": "跨電商收藏家居商品，依空間整理採購清單、預算與分享內容。資料只儲存在本機。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "開啟 RoomList 空間採購清單"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.ikea.com.tw/*",
    "https://www.ikea.com.hk/*",
    "https://planner.ikea.com.tw/*",
    "https://planner.ikea.com.hk/*",
    "https://24h.pchome.com.tw/*",
    "https://www.momoshop.com.tw/*",
    "https://shopee.tw/*",
    "https://www.tw.coupang.com/*",
    "https://www.nitori-net.tw/*",
    "https://www.trplus.com.tw/*",
    "https://detail.tmall.com/*",
    "https://item.taobao.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.ikea.com.tw/*",
        "https://www.ikea.com.hk/*",
        "https://planner.ikea.com.tw/*",
        "https://planner.ikea.com.hk/*",
        "https://24h.pchome.com.tw/*",
        "https://www.momoshop.com.tw/*",
        "https://shopee.tw/*",
        "https://www.tw.coupang.com/*",
        "https://www.nitori-net.tw/*",
        "https://www.trplus.com.tw/*",
        "https://detail.tmall.com/*",
        "https://item.taobao.com/*"
      ],
      "js": [
        "content/site-adapter.js",
        "content/storage.js",
        "content/panel.js",
        "content/content-script.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
